# =========================
# Sensitive user configs
# =========================
config/config.sh
config/folders.conf
config/exclude.conf
config/*.conf
config/*.key
config/*.token
config/*.secret
config/.env

# Allow example configs
!config/config.example.sh
!config/folders.example.conf
!config/exclude.example.conf

# =========================
# Rclone sensitive data
# =========================
.rclone.conf
rclone.conf
.config/rclone/rclone.conf

# =========================
# Runtime data (DO NOT COMMIT)
# =========================
logs/
state/
*.log
*.lock
/tmp/

# =========================
# Cache / system junk
# =========================
.cache/
**/.cache/
.local/share/Trash/
.snap/

# =========================
# Dev junk (IMPORTANT)
# =========================
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
**/.git/

# =========================
# Backup / temp files
# =========================
*.bak
*.part
*.tmp

# =========================
# Build artifacts
# =========================
dist/
build/
release/
*.tar.gz

# =========================
# System / OS junk
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor files
# =========================
*.swp
*.swo
.vscode/
.idea/

# =========================
# Systemd (only local overrides)
# =========================
*.service.local

# =========================
# Extra safety
# =========================
*.pem
*.key
*.env
info.md
docs/info.md
