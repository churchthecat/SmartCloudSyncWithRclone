# =========================
# Sensitive user configs
# =========================
config/config.sh
config/folders.conf
config/exclude.conf
config/*.key
config/*.token
config/.env
config/*.secret
config/*.conf

# Allow example configs
!config/config.example.sh
!config/folders.example.conf
!config/exclude.example.conf

# =========================
# Rclone sensitive data
# =========================
.rclone.conf
rclone.conf
.config/rclone/rclone.conf

# =========================
# Logs & temp
# =========================
*.log
*.lock
/tmp/
.cache/
.local/share/Trash/

# =========================
# Backup / temp files
# =========================
*.bak

# =========================
# Build artifacts
# =========================
dist/
build/
release/
*.tar.gz

# =========================
# System / OS junk
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor files
# =========================
*.swp
*.swo
.vscode/
.idea/

# =========================
# Systemd local units (optional)
# =========================
*.service

